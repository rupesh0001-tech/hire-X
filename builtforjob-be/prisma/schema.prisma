// Prisma Database Schema
// Run: bun run db:generate && bun run db:push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  bio       String?
  location  String?
  avatarUrl String?
  jobTitle  String?
  role            UserRole @default(USER)
  isVerified      Boolean  @default(false)
  faceDescriptor  Json?    // 128-float array from face-api.js
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company?

  // Profile Builder Relations
  skills      Skill[]
  experience  Experience[]
  education   Education[]
  projects    Project[]
  socialLinks Json?    @default("{}")

  otps              OTP[]
  passwordResetTokens PasswordResetToken[]

  // Document Management
  resumes      Resume[]
  coverLetters CoverLetter[]

  // Social Feed
  posts        Post[]
  likes        Like[]
  comments     Comment[]

  // Events
  events                Event[]
  eventRegistrations    EventRegistration[]

  @@map("users")
}

model Resume {
  id          String   @id @default(uuid())
  title       String
  company     String?
  template    String   @default("Modern")
  content     Json?    // Snapshot of the resume data
  isMagic     Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions    ResumeVersion[]

  @@map("resumes")
}

model ResumeVersion {
  id          String   @id @default(uuid())
  company     String?
  role        String
  resumeId    String
  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  status      String   @default("Active") // e.g., "Active", "Applied", "Draft"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("resume_versions")
}

model CoverLetter {
  id          String   @id @default(uuid())
  title       String
  company     String?
  recipient   String?
  content     String?   @db.Text
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("cover_letters")
}

model Skill {
  id             String   @id @default(uuid())
  name           String
  isGithubSynced Boolean  @default(false)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Experience {
  id          String   @id @default(uuid())
  company     String
  position    String
  startDate   String
  endDate     String?
  description String?
  isCurrent   Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id             String   @id @default(uuid())
  institution    String
  degree         String
  field          String
  graduationDate String
  gpa            String?
  graduationType String?  // e.g. "cgpa" or "percentage"
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Project {
  id             String   @id @default(uuid())
  name           String
  techStack      String?
  description    String?
  isGithubSynced Boolean  @default(false)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model OTP {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  code      String
  type      OTPType
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, type, isUsed])
  @@map("otps")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token, isUsed])
  @@map("password_reset_tokens")
}

enum OTPType {
  REGISTRATION
  PASSWORD_RESET
}

enum UserRole {
  USER
  FOUNDER
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Company {
  id                   String                @id @default(uuid())
  name                 String
  description          String?               @db.Text
  website              String?
  industry             String?
  logoUrl              String?               // ImageKit URL
  logoFileId           String?               // ImageKit file ID for deletion
  docUrl               String?               // Owner documentation ImageKit URL
  docFileId            String?               // ImageKit file ID
  docVerificationStatus DocVerificationStatus @default(PENDING)
  docRejectionReason   String?               @db.Text
  userId               String                @unique
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@map("companies")
}

enum DocVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// Social Feed

model Post {
  id            String     @id @default(uuid())
  type          PostType   @default(TEXT)
  content       String?    @db.Text
  imageUrl      String?
  imageFileId   String?
  authorId      String
  author        User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  isSponsored   Boolean    @default(false)
  promotedUntil DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([authorId])
  @@map("posts")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@map("comments")
}

enum PostType {
  TEXT
  IMAGE
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id                  String        @id @default(uuid())
  title               String
  description         String        @db.Text
  bannerUrl           String?
  bannerFileId        String?
  price               Int           // in paise (INR). 0 = free
  venue               String
  prize               String?
  maxParticipants     Int?
  eventDate           DateTime
  contactInfo         String
  organizerName       String
  status              EventStatus   @default(ACTIVE)
  
  // Listing fee payment (₹100)
  listingOrderId      String?
  listingPaymentId    String?
  isListed            Boolean       @default(false)  // true once listing fee paid

  organizerId         String
  organizer           User          @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  registrations       EventRegistration[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([organizerId])
  @@map("events")
}

model EventRegistration {
  id              String                    @id @default(uuid())
  eventId         String
  event           Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Participant details (captured at registration)
  participantName  String
  participantEmail String
  participantPhone String

  // Payment
  amountPaid       Int                       // in paise
  orderId          String?
  paymentId        String?
  paymentStatus    PaymentStatus             @default(PENDING)

  // Secret 5-digit attendance code — never exposed to host/admin
  attendanceCode   String

  // Attendance verification
  attendanceStatus AttendanceStatus          @default(NOT_VERIFIED)
  verifiedAt       DateTime?

  // Refund
  refundStatus     RefundStatus              @default(NONE)
  refundReason     String?

  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_registrations")
}

enum EventStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum AttendanceStatus {
  NOT_VERIFIED
  VERIFIED
  ABSENT
}

enum RefundStatus {
  NONE
  PENDING
  PROCESSED
}
